@{
    ViewData["Title"] = "ホーム";
    var userName = Context.Session.GetString(SessionKeys.UserName);
}

<div class="mb-4">
    <h1 class="h3">ホーム</h1>
    <p class="text-muted">@userName さんでログイン中です。</p>
    <div class="row g-3 mt-2">
        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5 card-title">部門一覧</h2>
                    <p class="card-text text-muted">部門情報を確認します。</p>
                    <a class="btn btn-primary mt-auto" asp-controller="Department" asp-action="Index">開く</a>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5 card-title">社員一覧</h2>
                    <p class="card-text text-muted">社員情報を確認します。</p>
                    <a class="btn btn-primary mt-auto" asp-controller="Employee" asp-action="Index">開く</a>
                </div>
            </div>
        </div>
    </div>
</div>
