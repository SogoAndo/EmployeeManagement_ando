@model EmployeeManagement.Web.ViewModels.DepartmentDetailViewModel

@{
    ViewData["Title"] = "部門詳細";
    var backUrl = string.IsNullOrWhiteSpace(Model.ReturnUrl) ? Url.Action("Index") : Model.ReturnUrl;
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">部門詳細</h1>
        <p class="text-muted mb-0">@Model.EmployeeCount 名が所属しています。</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" href="@backUrl">一覧へ戻る</a>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id" asp-route-returnUrl="@Model.CurrentUrl" asp-route-deleteReturnUrl="@Model.ReturnUrl">編集</a>
    </div>
</div>

<section class="mb-4">
    <h2 class="h5 border-bottom pb-2 mb-3">基本情報</h2>
    <dl class="row mb-0">
        <dt class="col-sm-3 col-lg-2">部門ID</dt>
        <dd class="col-sm-9 col-lg-10">@Model.Id</dd>
        <dt class="col-sm-3 col-lg-2">部門名</dt>
        <dd class="col-sm-9 col-lg-10">@Model.Name</dd>
        <dt class="col-sm-3 col-lg-2">所属社員数</dt>
        <dd class="col-sm-9 col-lg-10">@Model.EmployeeCount 名</dd>
    </dl>
</section>

<section class="mb-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 border-bottom pb-2 mb-3">
        <h2 class="h5 mb-0">所属社員</h2>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary btn-sm" asp-controller="Employee" asp-action="Create" asp-route-departmentId="@Model.Id" asp-route-returnUrl="@Model.CurrentUrl">この部門に社員登録</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle bg-white">
            <thead class="table-light">
                <tr>
                    <th scope="col" class="text-nowrap">社員番号</th>
                    <th scope="col">社員名</th>
                    <th scope="col">メールアドレス</th>
                    <th scope="col" class="text-nowrap">入社日</th>
                    <th scope="col" class="text-nowrap">操作</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Employees.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">所属社員はいません。</td>
                    </tr>
                }
                else
                {
                    foreach (var employee in Model.Employees)
                    {
                        <tr>
                            <td class="text-nowrap">@employee.EmployeeNo</td>
                            <td>@employee.Name</td>
                            <td>@employee.Email</td>
                            <td class="text-nowrap">@employee.HireDateText</td>
                            <td class="text-nowrap">
                                <div class="d-flex gap-2">
                                    <a class="btn btn-outline-secondary btn-sm" asp-controller="Employee" asp-action="Details" asp-route-id="@employee.Id" asp-route-returnUrl="@Model.CurrentUrl">詳細</a>
                                    <a class="btn btn-outline-primary btn-sm" asp-controller="Employee" asp-action="Edit" asp-route-id="@employee.Id" asp-route-returnUrl="@Model.CurrentUrl">編集</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>

<section class="mb-4">
    <h2 class="h5 border-bottom pb-2 mb-3">確認情報</h2>
    <dl class="row mb-0">
        <dt class="col-sm-3 col-lg-2">登録者</dt>
        <dd class="col-sm-9 col-lg-10">@Model.CreatedByName</dd>
        <dt class="col-sm-3 col-lg-2">登録日時</dt>
        <dd class="col-sm-9 col-lg-10">@Model.CreatedAtText</dd>
        <dt class="col-sm-3 col-lg-2">更新者</dt>
        <dd class="col-sm-9 col-lg-10">@Model.UpdatedByName</dd>
        <dt class="col-sm-3 col-lg-2">更新日時</dt>
        <dd class="col-sm-9 col-lg-10">@Model.UpdatedAtText</dd>
    </dl>
</section>
