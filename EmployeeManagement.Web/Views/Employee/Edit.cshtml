@model EmployeeManagement.Web.ViewModels.EmployeeFormViewModel

@{
    ViewData["Title"] = "社員編集";
    var backUrl = string.IsNullOrWhiteSpace(Model.ReturnUrl) ? Url.Action("Index") : Model.ReturnUrl;
    var deleteCancelUrl = Url.Action("Edit", new { id = Model.Id, returnUrl = Model.ReturnUrl, deleteReturnUrl = Model.DeleteReturnUrl });
    var loginUserReturnUrl = Url.Action("Edit", new { id = Model.Id, returnUrl = Model.ReturnUrl, deleteReturnUrl = Model.DeleteReturnUrl });
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">社員編集</h1>
    </div>
    <div class="d-flex flex-wrap gap-2">
        @if (Model.CanManageLoginUser)
        {
            <a class="btn btn-outline-primary" asp-action="LoginUser" asp-route-id="@Model.Id" asp-route-returnUrl="@loginUserReturnUrl">
                @(Model.HasLoginUser ? "ログイン情報編集" : "ログイン情報登録")
            </a>
        }
        <a class="btn btn-outline-secondary" href="@backUrl">一覧へ戻る</a>
    </div>
</div>

<form asp-action="Edit" method="post" class="employee-form">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="ReturnUrl" type="hidden" />
    <input asp-for="DeleteReturnUrl" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <section class="mb-4">
        <h2 class="h5 border-bottom pb-2 mb-3">基本情報</h2>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="field-label-line">
                    <label asp-for="EmployeeNo" class="form-label mb-0"></label>
                    <span class="field-requirement field-required">必須</span>
                </div>
                <input asp-for="EmployeeNo" class="form-control" />
                <span asp-validation-for="EmployeeNo" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <div class="field-label-line">
                    <label asp-for="Name" class="form-label mb-0"></label>
                    <span class="field-requirement field-required">必須</span>
                </div>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <div class="field-label-line">
                    <label asp-for="DepartmentId" class="form-label mb-0"></label>
                    <span class="field-requirement field-required">必須</span>
                </div>
                <select asp-for="DepartmentId" asp-items="Model.DepartmentOptions" class="form-select"></select>
                <span asp-validation-for="DepartmentId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <div class="field-label-line">
                    <label asp-for="Email" class="form-label mb-0"></label>
                    <span class="field-requirement field-optional">任意</span>
                </div>
                <input asp-for="Email" type="email" maxlength="100" autocomplete="email" class="form-control" placeholder="example@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <div class="field-label-line">
                    <label asp-for="HireDate" class="form-label mb-0"></label>
                    <span class="field-requirement field-required">必須</span>
                </div>
                <input asp-for="HireDate" asp-format="{0:yyyy-MM-dd}" type="date" class="form-control" />
                <span asp-validation-for="HireDate" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="mb-4">
        <h2 class="h5 border-bottom pb-2 mb-3">確認情報</h2>
        <dl class="row mb-0">
            @if (Model.CanManageLoginUser || Model.HasLoginUser)
            {
                <dt class="col-sm-3 col-lg-2">ログイン情報</dt>
                <dd class="col-sm-9 col-lg-10">
                    <span class="badge @(Model.HasLoginUser ? "text-bg-success" : "text-bg-secondary")">
                        @(Model.HasLoginUser ? "設定済み" : "未設定")
                    </span>
                </dd>
            }
            <dt class="col-sm-3 col-lg-2">登録者</dt>
            <dd class="col-sm-9 col-lg-10">@Model.CreatedByName</dd>
            <dt class="col-sm-3 col-lg-2">登録日時</dt>
            <dd class="col-sm-9 col-lg-10">@Model.CreatedAtText</dd>
            <dt class="col-sm-3 col-lg-2">更新者</dt>
            <dd class="col-sm-9 col-lg-10">@Model.UpdatedByName</dd>
            <dt class="col-sm-3 col-lg-2">更新日時</dt>
            <dd class="col-sm-9 col-lg-10">@Model.UpdatedAtText</dd>
        </dl>
    </section>

    <div class="d-flex flex-wrap justify-content-between gap-2">
        <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id" asp-route-returnUrl="@Model.DeleteReturnUrl" asp-route-cancelUrl="@deleteCancelUrl">削除</a>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary" href="@backUrl">キャンセル</a>
            <button type="submit" class="btn btn-primary">更新する</button>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
