@model EmployeeManagement.Web.ViewModels.EmployeeDetailViewModel

@{
    ViewData["Title"] = "社員詳細";
    var backUrl = string.IsNullOrWhiteSpace(Model.ReturnUrl) ? Url.Action("Index") : Model.ReturnUrl;
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">社員詳細</h1>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" href="@backUrl">一覧へ戻る</a>
        @if (Model.CanManageLoginUser)
        {
            <a class="btn btn-outline-primary" asp-action="LoginUser" asp-route-id="@Model.Id" asp-route-returnUrl="@Model.CurrentUrl">
                @(Model.HasLoginUser ? "ログイン情報編集" : "ログイン情報登録")
            </a>
        }
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id" asp-route-returnUrl="@Model.CurrentUrl" asp-route-deleteReturnUrl="@Model.ReturnUrl">編集</a>
    </div>
</div>

<section class="mb-4">
    <h2 class="h5 border-bottom pb-2 mb-3">基本情報</h2>
    <dl class="row mb-0">
        <dt class="col-sm-3 col-lg-2">社員番号</dt>
        <dd class="col-sm-9 col-lg-10">@Model.EmployeeNo</dd>
        <dt class="col-sm-3 col-lg-2">社員名</dt>
        <dd class="col-sm-9 col-lg-10">@Model.Name</dd>
        <dt class="col-sm-3 col-lg-2">メールアドレス</dt>
        <dd class="col-sm-9 col-lg-10">@Model.Email</dd>
        <dt class="col-sm-3 col-lg-2">入社日</dt>
        <dd class="col-sm-9 col-lg-10">@Model.HireDateText</dd>
        <dt class="col-sm-3 col-lg-2">部門</dt>
        <dd class="col-sm-9 col-lg-10">
            <a asp-controller="Department" asp-action="Details" asp-route-id="@Model.DepartmentId" asp-route-returnUrl="@Model.CurrentUrl">@Model.DepartmentName</a>
        </dd>
        <dt class="col-sm-3 col-lg-2">ログイン情報</dt>
        <dd class="col-sm-9 col-lg-10">
            @if (Model.HasLoginUser)
            {
                <span class="badge text-bg-success">設定済み</span>
            }
            else if (Model.CanManageLoginUser)
            {
                <span class="badge text-bg-secondary">未設定</span>
            }
            else
            {
                <span class="text-muted">対象外</span>
            }
        </dd>
    </dl>
</section>

<section class="mb-4">
    <h2 class="h5 border-bottom pb-2 mb-3">確認情報</h2>
    <dl class="row mb-0">
        <dt class="col-sm-3 col-lg-2">登録者</dt>
        <dd class="col-sm-9 col-lg-10">@Model.CreatedByName</dd>
        <dt class="col-sm-3 col-lg-2">登録日時</dt>
        <dd class="col-sm-9 col-lg-10">@Model.CreatedAtText</dd>
        <dt class="col-sm-3 col-lg-2">更新者</dt>
        <dd class="col-sm-9 col-lg-10">@Model.UpdatedByName</dd>
        <dt class="col-sm-3 col-lg-2">更新日時</dt>
        <dd class="col-sm-9 col-lg-10">@Model.UpdatedAtText</dd>
    </dl>
</section>
