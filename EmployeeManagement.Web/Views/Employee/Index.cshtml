@model EmployeeManagement.Web.ViewModels.EmployeeIndexViewModel

@{
    ViewData["Title"] = "社員一覧";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">社員一覧</h1>
        <p class="text-muted mb-0">@Model.Employees.Count 件表示</p>
    </div>
    <a class="btn btn-primary" asp-action="Create" asp-route-departmentId="@Model.DepartmentId" asp-route-returnUrl="@Model.ReturnUrl">社員登録</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.SelectedDepartmentName))
{
    <div class="alert alert-info d-flex flex-wrap justify-content-between align-items-center gap-2" role="status">
        <span>部門「@Model.SelectedDepartmentName」の社員を表示しています。</span>
        @if (!string.IsNullOrWhiteSpace(Model.BackUrl))
        {
            <a class="btn btn-outline-primary btn-sm" href="@Model.BackUrl">元の画面へ戻る</a>
        }
        else
        {
            <a class="btn btn-outline-primary btn-sm" asp-controller="Department" asp-action="Details" asp-route-id="@Model.DepartmentId" asp-route-returnUrl="@Model.ReturnUrl">部門詳細を見る</a>
        }
    </div>
}
else if (!string.IsNullOrWhiteSpace(Model.BackUrl))
{
    <div class="alert alert-secondary d-flex flex-wrap justify-content-between align-items-center gap-2" role="status">
        <span>元の画面から社員一覧を表示しています。</span>
        <a class="btn btn-outline-secondary btn-sm" href="@Model.BackUrl">元の画面へ戻る</a>
    </div>
}

<section class="mb-4">
    <form asp-action="Index" method="get" class="row g-3 align-items-end">
        @if (!string.IsNullOrWhiteSpace(Model.BackUrl))
        {
            <input type="hidden" name="returnUrl" value="@Model.BackUrl" />
        }
        <div class="col-md-3">
            <label asp-for="EmployeeNo" class="form-label">社員番号</label>
            <input asp-for="EmployeeNo" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Name" class="form-label">社員名</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="DepartmentId" class="form-label">部門</label>
            <select asp-for="DepartmentId" asp-items="Model.DepartmentOptions" class="form-select"></select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-primary">検索</button>
        </div>
        <div class="col-auto">
            <a class="btn btn-outline-secondary" asp-action="Index" asp-route-returnUrl="@Model.BackUrl">クリア</a>
        </div>
    </form>
</section>

<section>
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle bg-white">
            <thead class="table-light">
                <tr>
                    <th scope="col" class="text-nowrap">社員番号</th>
                    <th scope="col">社員名</th>
                    <th scope="col">部門</th>
                    <th scope="col">メールアドレス</th>
                    <th scope="col" class="text-nowrap">入社日</th>
                    <th scope="col">更新者</th>
                    <th scope="col" class="text-nowrap">更新日</th>
                    <th scope="col" class="text-nowrap">操作</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Employees.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">該当する社員はありません。</td>
                    </tr>
                }
                else
                {
                    foreach (var employee in Model.Employees)
                    {
                        <tr>
                            <td class="text-nowrap">@employee.EmployeeNo</td>
                            <td>@employee.Name</td>
                            <td>
                                <a asp-controller="Department" asp-action="Details" asp-route-id="@employee.DepartmentId" asp-route-returnUrl="@Model.ReturnUrl">@employee.DepartmentName</a>
                            </td>
                            <td>@employee.Email</td>
                            <td class="text-nowrap">@employee.HireDateText</td>
                            <td>@employee.UpdatedByName</td>
                            <td class="text-nowrap">@employee.UpdatedAtText</td>
                            <td class="text-nowrap">
                                <div class="d-flex gap-2">
                                    <a class="btn btn-outline-secondary btn-sm" asp-action="Details" asp-route-id="@employee.Id" asp-route-returnUrl="@Model.ReturnUrl">詳細</a>
                                    <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@employee.Id" asp-route-returnUrl="@Model.ReturnUrl">編集</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
