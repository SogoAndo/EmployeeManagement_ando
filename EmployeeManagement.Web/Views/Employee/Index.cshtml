@model EmployeeManagement.Web.ViewModels.EmployeeIndexViewModel

@{
    ViewData["Title"] = "社員一覧";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">社員一覧</h1>
    </div>
    <a class="btn btn-primary" asp-action="Create">社員登録</a>
</div>

<section class="mb-4">
    <form asp-action="Index" method="get" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label asp-for="EmployeeNo" class="form-label">社員番号</label>
            <input asp-for="EmployeeNo" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Name" class="form-label">社員名</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="DepartmentId" class="form-label">部門</label>
            <select asp-for="DepartmentId" asp-items="Model.DepartmentOptions" class="form-select"></select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-primary">検索</button>
        </div>
        <div class="col-auto">
            <a class="btn btn-outline-secondary" asp-action="Index">クリア</a>
        </div>
    </form>
</section>

<section>
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle bg-white">
            <thead class="table-light">
                <tr>
                    <th scope="col" class="text-nowrap">社員番号</th>
                    <th scope="col">社員名</th>
                    <th scope="col">部門</th>
                    <th scope="col">メールアドレス</th>
                    <th scope="col" class="text-nowrap">入社日</th>
                    <th scope="col">更新者</th>
                    <th scope="col" class="text-nowrap">更新日</th>
                    <th scope="col" class="text-nowrap">操作</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Employees.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">該当する社員はありません。</td>
                    </tr>
                }
                else
                {
                    foreach (var employee in Model.Employees)
                    {
                        <tr>
                            <td class="text-nowrap">@employee.EmployeeNo</td>
                            <td>@employee.Name</td>
                            <td>@employee.DepartmentName</td>
                            <td>@employee.Email</td>
                            <td class="text-nowrap">@employee.HireDateText</td>
                            <td>@employee.UpdatedByName</td>
                            <td class="text-nowrap">@employee.UpdatedAtText</td>
                            <td class="text-nowrap">
                                <div class="d-flex gap-2">
                                    <a class="btn btn-outline-secondary btn-sm" asp-action="Details" asp-route-id="@employee.Id">詳細</a>
                                    <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@employee.Id">編集</a>
                                    <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@employee.Id">削除</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
